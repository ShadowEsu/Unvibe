# Unvibe marketing site environment variables.
# Copy to .env.local only if you want durable Blob storage, admin lock, email, or analytics.
# With no env file at all, waitlist signups and /waitlist-admin work against a local JSON file.

# Optional durable waitlist storage. When both are set, signups are encrypted in Vercel Blob.
# If either is missing, the site falls back to .data/waitlist.json (or /tmp on Vercel).
BLOB_READ_WRITE_TOKEN=
WAITLIST_ADMIN_TOKEN=

# Public site URL, used for metadata, sitemap, robots, and referral links.
NEXT_PUBLIC_SITE_URL=https://unvibe.site

# Server-only URL for the existing Unvibe API used by /app. Keep this HTTPS in production.
# Defaults to https://api.unvibe.site when omitted. Do not expose it through NEXT_PUBLIC_.
UNVIBE_APP_BACKEND_URL=https://api.unvibe.site

# Analytics (optional). When NEXT_PUBLIC_POSTHOG_KEY is empty, analytics is a no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Waitlist alerts are always sent to preston@unvibe.site by the server.
# This legacy variable is ignored so a deployment cannot accidentally redirect signup alerts.
WAITLIST_NOTIFY_EMAIL=preston@unvibe.site

# Optional email provider. Without RESEND_API_KEY, signups still save; founder email is skipped.
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=Unvibe Waitlist <onboarding@resend.com>

# The beta-invite sender uses the same Resend key and sender. First run
# `npm run send:beta-invites` to inspect recipients; add `-- --send` only when ready.

# Optional demo video URL, or place a file at public/demo.mp4
NEXT_PUBLIC_DEMO_VIDEO_URL=

# Optional overrides for /investors demo media (defaults to the public Blob objects).
NEXT_PUBLIC_INVESTOR_DEMO_VIDEO_URL=
NEXT_PUBLIC_INVESTOR_DMG_URL=
