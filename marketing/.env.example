# Unvibe marketing site environment variables.
# Copy to .env.local and fill in as needed. Local development can omit the durable-storage
# values and writes waitlist entries to the gitignored .data/waitlist.json file instead.

# Production waitlist storage. Connect a dedicated Vercel Blob store to provision this token.
# The application encrypts each waitlist payload before upload, even though the Blob API uses
# a public-access object URL. Never expose either value through a NEXT_PUBLIC_ variable.
BLOB_READ_WRITE_TOKEN=

# Long, random server-only secret used to authorize /waitlist-admin and encrypt stored entries.
# Rotating it makes existing encrypted waitlist data unreadable, so store and rotate it carefully.
WAITLIST_ADMIN_TOKEN=

# Public site URL, used for metadata, sitemap, robots, and referral links.
NEXT_PUBLIC_SITE_URL=https://unvibe.site

# Server-only URL for the existing Unvibe API used by /app. Keep this HTTPS in production.
# Defaults to https://api.unvibe.site when omitted. Do not expose it through NEXT_PUBLIC_.
UNVIBE_APP_BACKEND_URL=https://api.unvibe.site

# Analytics (optional). When NEXT_PUBLIC_POSTHOG_KEY is empty, analytics is a no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Waitlist alerts are always sent to preston@unvibe.site by the server.
# This legacy variable is ignored so a deployment cannot accidentally redirect signup alerts.
WAITLIST_NOTIFY_EMAIL=preston@unvibe.site

# Recommended email provider. Verify unvibe.site in Resend for production sending.
# Until the domain is verified, onboarding@resend.com can send only to the Resend account email.
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=Unvibe Waitlist <onboarding@resend.com>

# Optional demo video URL, or place a file at public/demo.mp4
NEXT_PUBLIC_DEMO_VIDEO_URL=
