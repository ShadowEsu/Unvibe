# Unvibe marketing site environment variables.
# Copy to .env.local and fill in as needed. All are optional for local development:
# without Supabase, waitlist entries are written to .data/waitlist.json instead.

# Supabase (waitlist storage). Use the secret / service-role key on the server only —
# never expose it to the browser. When unset, the API falls back to a local JSON file.
# Project URL looks like: https://YOUR_PROJECT_REF.supabase.co
# Prefer the sb_secret_... key (or the legacy service_role JWT) for SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Not required for the waitlist API (server uses the secret key).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public site URL, used for metadata, sitemap, robots, and referral links.
NEXT_PUBLIC_SITE_URL=https://unvibe.app

# Analytics (optional). When NEXT_PUBLIC_POSTHOG_KEY is empty, analytics is a no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Founder inbox for new waitlist signups (FormSubmit). Confirm the first email.
WAITLIST_NOTIFY_EMAIL=prestonjaysusanto@gmail.com

# Optional demo video URL, or place a file at public/demo.mp4
NEXT_PUBLIC_DEMO_VIDEO_URL=
