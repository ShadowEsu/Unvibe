{
  "name": "unvibe-app",
  "version": "0.1.1",
  "private": true,
  "description": "Unvibe desktop — floating learning layer for code",
  "main": "dist/main/main.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/build.mjs --tests && node --test dist-test/*.test.js",
    "dist": "npm run build && electron-builder --mac dir",
    "dist:dmg": "npm run build && electron-builder --mac dmg",
    "package:local": "node scripts/package-local.mjs",
    "package:release": "node scripts/package-release.mjs",
    "package:dmg-layout": "node scripts/create-custom-dmg.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "open": "npm run dist && open \"release/mac-arm64/Unvibe.app\" || open \"release/mac/Unvibe.app\""
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.unvibe.app",
    "productName": "Unvibe",
    "copyright": "Copyright © 2026 Unvibe",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.icns",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "CFBundleDisplayName": "Unvibe",
        "CFBundleName": "Unvibe",
        "NSAccessibilityUsageDescription": "Unvibe reads the code you have selected in another app when you press the shortcut, so it can explain it.",
        "LSUIElement": false
      }
    },
    "dmg": {
      "sign": false,
      "title": "Install Unvibe",
      "artifactName": "Unvibe-${version}-${arch}-unsigned.${ext}",
      "background": "build/dmg-background.png",
      "window": {
        "width": 780,
        "height": 500
      },
      "iconSize": 88,
      "contents": [
        {
          "x": 230,
          "y": 290,
          "type": "file"
        },
        {
          "x": 550,
          "y": 290,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
