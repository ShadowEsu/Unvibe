{
  "name": "unvibe-app",
  "version": "0.1.2",
  "private": true,
  "description": "Unvibe desktop — floating learning layer for code",
  "main": "dist/main/main.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/build.mjs --tests && node --test dist-test/*.test.js",
    "dist": "npm run build && electron-builder --mac dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win",
    "open": "npm run dist && open \"release/mac-arm64/Unvibe.app\" || open \"release/mac/Unvibe.app\""
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.unvibe.app",
    "productName": "Unvibe",
    "copyright": "Copyright © 2026 Unvibe",
    "files": ["dist/**/*", "package.json"],
    "directories": { "output": "release", "buildResources": "build" },
    "icon": "build/icon.png",
    "afterSign": "scripts/afterSignHook.cjs",
    "artifactName": "Unvibe-${version}-${os}-${arch}.${ext}",
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "CFBundleDisplayName": "Unvibe",
        "CFBundleName": "Unvibe",
        "NSAccessibilityUsageDescription": "Unvibe reads the code you have selected in another app when you press the shortcut, so it can explain it.",
        "LSUIElement": false
      }
    },
    "dmg": { "sign": false },
    "win": {
      "icon": "build/icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "artifactName": "Unvibe-${version}-${os}-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Unvibe-${version}-${os}-${arch}-portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "ShadowEsu",
      "repo": "Unvibe"
    }
  }
}
