# Unvibe desktop app — environment (all optional)
#
# The app performs NO direct AI calls and holds NO secret keys. It talks only to the backend
# over HTTPS. Keys live on the backend (web/.env). See web/.env.example for AI + Supabase config.

# Required for cloud features. Safe to embed in the Electron MAIN process, never the renderer.
# Default: http://localhost:8787. Staging/prod must be HTTPS and must not use localhost.
UNVIBE_BACKEND=http://localhost:8788

# Optional environment label used only for diagnostics and release checks.
APP_ENV=development
# The custom scheme reserved for a future verified browser-to-app callback. No secrets.
DEEP_LINK_SCHEME=unvibe
