# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
out/
*.vsix
.next/
build/
# ...but app/build/ holds source assets (app + tray icons, entitlements), not build output.
# Ignore its generated contents, then whitelist the committed source files.
!app/build/
app/build/*
!app/build/icon.icns
!app/build/icon.png
!app/build/trayTemplate.png
!app/build/entitlements.mac.plist

# Env & secrets (never commit)
.env
.env.*
web/env.local
!.env.example
*.pem
*.key

# Logs & OS
*.log
.DS_Store

# Editor
.vscode-test/
