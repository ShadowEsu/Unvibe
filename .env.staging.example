# Copy to a secure, ignored file outside version control. Never put production values here.
APP_ENV=staging
STAGING_CONFIRMATION=UNVIBE_STAGING_ONLY
STAGING_ALLOW_DESTRUCTIVE_TESTS=false

# Guardrails: the project ref must match the first label of SUPABASE_URL. If a production
# ref is supplied, the verifier refuses to continue when the refs match.
STAGING_PROJECT_REF=replace-with-staging-project-ref
PRODUCTION_SUPABASE_PROJECT_REF=replace-with-production-project-ref
STAGING_ALLOWED_SUPABASE_HOSTS=replace-with-staging-project-ref.supabase.co

SUPABASE_URL=https://replace-with-staging-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

WEB_BASE_URL=https://staging.example.com
PRODUCTION_WEB_BASE_URL=https://app.example.com
UNVIBE_BACKEND=https://staging.example.com

# Keep external/paid providers disabled until the founder explicitly runs the provider checklist.
AI_PROVIDER_MODE=mock
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
