# Uncode backend environment. Set these in deployment secrets, never in Electron or browser code.
# APP_ENV: development | staging | production. Staging/production must not silently use MemoryStore or mock AI.
APP_ENV=development
WEB_BASE_URL=http://localhost:8787
LOG_LEVEL=info
ENABLE_ANALYTICS=false

# AI — required for real explanations in staging/production. Server-only.
# Prefer one of: ANTHROPIC_API_KEY (Claude) or GEMINI_API_KEY (Google AI Studio, often AQ.…).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
UNCODE_MODEL=claude-sonnet-5
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_TOKENS=1024
# Plan limits are centralized in src/billing/plans.ts and enforced server-side.
ENABLE_MOCK_AI=true

# Supabase — SUPABASE_URL and service-role key are required for real sync. Server-only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Authentication safety
# Direct email sign-in is a local-development convenience only. Leave false in production;
# production builds must use the verified device/auth flow before they issue bearer tokens.
UNCODE_ALLOW_DEV_EMAIL_AUTH=false

# Billing — server-only. Leave unset to keep checkout disabled. Configure TEST mode first.
# PUBLIC_APP_URL is the dashboard origin used for trusted Checkout/Portal return URLs.
PUBLIC_APP_URL=http://localhost:8787
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TEAMS_MONTHLY=
STRIPE_PRICE_TEAMS_ANNUAL=
BILLING_GRACE_PERIOD_DAYS=7
